# ─────────── IoT Edge Gateway Configuration (edge_gateway.py) ───────────
DEVICE_ID=rpi-nutriguard-01
PORT=5000
SAMPLE_INTERVAL_S=2
WINDOW_SECONDS=20
DHT_GPIO=4
LOG_LEVEL=INFO
# Set to 1 for non-RPi environment debugging, using mock data
MOCK_SENSOR=0

# ─────────── Blockchain Direct Connection to Chain (chain_agent.py, M3 enabled) ───────────
# Hardhat node (development machine IP, e.g. 192.168.1.100)
ETH_RPC_URL=http://172.20.10.4:8545
CHAIN_ID=1337
# Hardhat default merchant account, only for local demo, do not use on public network
MERCHANT_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
# Update to the latest contract address after deployment
CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
ABI_PATH=./abi/NutriGuard.json
