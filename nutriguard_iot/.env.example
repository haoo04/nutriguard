# ─────────── 边缘网关配置 (edge_gateway.py) ───────────
DEVICE_ID=rpi-nutriguard-01
PORT=5000
SAMPLE_INTERVAL_S=2
WINDOW_SECONDS=20
DHT_GPIO=4
LOG_LEVEL=INFO
# 非 RPi 环境调试时设为 1, 使用伪随机数据
MOCK_SENSOR=0

# ─────────── 区块链直连上链 (chain_agent.py, M3 启用) ───────────
# Hardhat 节点 (开发机 IP, 例如 192.168.1.100)
ETH_RPC_URL=http://192.168.1.100:8545
CHAIN_ID=1337
# Hardhat 默认商家账户, 仅本地 Demo, 切勿在公网复用
MERCHANT_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
# 部署后更新为最新合约地址
CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
ABI_PATH=./abi/NutriGuard.json
